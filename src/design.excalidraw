      "versionNonce": 1383883084,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772811542643,
      "link": null,
      "locked": false,
      "text": "Requirements:\n- There will be requests\n- Each request should be processed by a server\n- Requests can be flooded, so there should be a Rate Limiter\n- The main work of rate limiter is to limit the number of request\n- Every user is allowed to send atmost 3 requests per second\n",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 164,
      "containerId": null,
      "originalText": "Requirements:\n- There will be requests\n- Each request should be processed by a server\n- Requests can be flooded, so there should be a Rate Limiter\n- The main work of rate limiter is to limit the number of request\n- Every user is allowed to send atmost 3 requests per second\n",
      "lineHeight": 1.2
    },
    {
      "id": "4HLimh-niDxAR99QlhGtS",
      "type": "text",
      "x": 511,
      "y": 385,
      "width": 1042.96875,
      "height": 144,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
