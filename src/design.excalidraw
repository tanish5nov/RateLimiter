      "roundness": null,
      "seed": 1470464628,
      "version": 392,
      "versionNonce": 1501038924,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1772811780982,
      "link": null,
      "locked": false,
      "text": "Objects:\n- Request: contains the info of who generated and info regarding what is the request\n- Server: Request after passing the rate limiter reaches the server\n- User: Generates a request, has a limit of how many requests they can process per second\n\n",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 140,
      "containerId": null,
      "originalText": "Objects:\n- Request: contains the info of who generated and info regarding what is the request\n- Server: Request after passing the rate limiter reaches the server\n- User: Generates a request, has a limit of how many requests they can process per second\n\n",
      "lineHeight": 1.2
    },
